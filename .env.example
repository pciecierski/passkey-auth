# Lokalnie (bez Dockera) — SQLite, działa od razu:
DATABASE_URL="file:./dev.db"

# Lokalnie z Dockerem:
# DATABASE_URL="postgresql://passkey:passkey@localhost:5432/passkey_auth"

# Na Railway: dodaj plugin PostgreSQL — Railway ustawi DATABASE_URL automatycznie.

RP_NAME="DC LOG Passkey Auth"
# Tylko domena — BEZ https:// i bez ścieżki:
RP_ID="passkey-auth.dcsandbox.dev"
# Pełny adres z protokołem:
ORIGIN="https://passkey-auth.dcsandbox.dev"
SESSION_SECRET="change-me-in-production-use-openssl-rand-hex-32"

# Opcjonalnie: publiczny URL dla kodów QR w dev (adres sieciowy komputera, np. http://10.0.0.5:3000)
# NEXT_PUBLIC_APP_URL="http://10.99.4.36:3000"
